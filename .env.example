# Beehiiv newsletter integration
# Onde obter (no painel da Beehiiv):
#   Settings → Integrations → API  → cria uma API key (scope subscriptions:write)
#   O Publication ID aparece nessa mesma página, no formato pub_xxxxxxxx-...
# Copie este ficheiro para .env.local e preencha os valores (NÃO comitar .env.local).

BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=
