# Beehiiv newsletter integration
# Onde obter (no painel da Beehiiv):
#   Settings → Integrations → API  → cria uma API key (scope subscriptions:write)
#   O Publication ID aparece nessa mesma página, no formato pub_xxxxxxxx-...
# Copie este ficheiro para .env.local e preencha os valores (NÃO comitar .env.local).

BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Supabase — Transaction Room (/admin, uso interno)
# Criar projeto em supabase.com → Settings → API (URL + anon/public key).
# Rodar supabase/schema.sql no SQL Editor e criar os usuários da equipe em
# Authentication → Users (sem sign-up público). Definir também no Vercel.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave SECRETA (service role) — /admin/users: convites, ban, listagem de contas.
# Settings → API → Secret keys no Supabase. Só no servidor: NUNCA prefixar com
# NEXT_PUBLIC_, nunca commitar, nunca logar. Definir também no Vercel.
SUPABASE_SERVICE_ROLE_KEY=
